APP_ENV=development
APP_PORT=8080
APP_BASE_URL=http://localhost:8080
FRONTEND_URL=http://localhost:3000

JWT_SECRET=super-secret
JWT_EXPIRES_IN=168h

DATABASE_URL=postgres://postgres:password@localhost:5432/myevent?sslmode=disable

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
